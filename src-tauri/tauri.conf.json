{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vibrant-dawn-taskbar",
  "version": "0.1.0",
  "identifier": "com.alexc.vibrant-dawn-taskbar",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "vibrant-dawn-taskbar",
        "width": 1938,
        "height": 48,
        "x": 0,
        "y": 1032,
        "resizable": false,
        "shadow": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "skipTaskbar": true
      },
      {
        "title": "Media Flyout",
        "label": "media_card",
        "url": "/media-card",
        "width": 300,
        "height": 400,
        "visible": false,
        "resizable": false,
        "shadow": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      },
      {
        "title": "Control Menu",
        "label": "control_menu",
        "url": "/control-menu",
        "width": 450,
        "height": 240,
        "visible": false,
        "resizable": false,
        "shadow": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      },
      {
        "title": "Icon Menu",
        "label": "icon_menu",
        "url": "/icon-menu",
        "width": 268,
        "height": 129,
        "visible": false,
        "resizable": false,
        "shadow": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      },
      {
        "title": "Notifications center",
        "label": "notifications_center",
        "url": "/notifications-center",
        "width": 400,
        "height": 600,
        "visible": false,
        "resizable": false,
        "shadow": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}